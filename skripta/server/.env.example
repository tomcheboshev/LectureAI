# Google AI Studio API Key
GEMINI_API_KEY=

# Database and Server Config
MONGODB_URI=mongodb://127.0.0.1:27017/skripta
PORT=3000

# Model used for generation + chatbot
GEMINI_MODEL=gemini-1.5-flash

# Optional: restrict CORS to a specific frontend origin in production
# CLIENT_ORIGIN=https://your-frontend.example.com

# Auth: JWT signing secrets — generate with `openssl rand -hex 48`, keep private
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Base URL of the frontend, used to build email verification / password reset links
CLIENT_URL=http://localhost:5173
